# ── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
CHAT_MODEL=llama3.1:8b

# ── Retrieval tuning ─────────────────────────────────────────────────────────
CHUNK_TOKENS=700
CHUNK_OVERLAP=120
TOP_K=12
CONTEXT_CHUNKS_TO_LLM=6
# Distance threshold – chunks above this value are dropped (lower = stricter)
DISTANCE_THRESHOLD=1.2

# ── API server ───────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000

# ── Conversation history ──────────────────────────────────────────────────────
# How many previous turns to include as context for the LLM
HISTORY_TURNS=4
